\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{block\PYGZus{}attn\PYGZus{}res}\PYG{p}{(}\PYG{n}{blocks}\PYG{p}{:} \PYG{n+nb}{list}\PYG{p}{[}\PYG{n}{Tensor}\PYG{p}{],} \PYG{n}{partial\PYGZus{}block}\PYG{p}{:} \PYG{n}{Tensor}\PYG{p}{,} \PYG{n}{proj}\PYG{p}{:} \PYG{n}{Linear}\PYG{p}{,} \PYG{n}{norm}\PYG{p}{:} \PYG{n}{RMSNorm}\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{Tensor}\PYG{p}{:}
