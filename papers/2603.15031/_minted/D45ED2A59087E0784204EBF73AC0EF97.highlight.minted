\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{forward}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{p}{,} \PYG{n}{blocks}\PYG{p}{:} \PYG{n+nb}{list}\PYG{p}{[}\PYG{n}{Tensor}\PYG{p}{],} \PYG{n}{hidden\PYGZus{}states}\PYG{p}{:} \PYG{n}{Tensor}\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n+nb}{tuple}\PYG{p}{[}\PYG{n+nb}{list}\PYG{p}{[}\PYG{n}{Tensor}\PYG{p}{],} \PYG{n}{Tensor}\PYG{p}{]:}
