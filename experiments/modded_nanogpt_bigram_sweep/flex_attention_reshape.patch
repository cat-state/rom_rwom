From: ROM Benchmark <rom-benchmark@local>
Date: Mon, 11 May 2026 15:01:13 -0400
Subject: [PATCH] Allow paired FlexAttention reshape

---
 train_gpt.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/train_gpt.py b/train_gpt.py
index 4e6fff8..de762bb 100644
--- a/train_gpt.py
+++ b/train_gpt.py
@@ -1155,7 +1155,7 @@ class CausalSelfAttention(nn.Module):
             max_len = 2 * max_len
 
         y = flex_varlen_window_attention(q, k, v, seqlens, bm_size, yarn.attn_scale)
-        y = y.view(B, T, self.num_heads, self.head_dim)
+        y = y.reshape(B, T, self.num_heads, self.head_dim)
         y = y * torch.sigmoid(F.linear(x[..., :12], attn_gate_w)).view(B, T, self.num_heads, 1)
         y = y.contiguous().view(B, T, self.num_heads * self.head_dim) # re-assemble all head outputs side by side
         y = F.linear(y, sa_lambdas[1] * qkvo_w[self.dim * 3:].type_as(y))  # sa_lambdas[1] pre-multiplied to O @shenberg
