From 9326d904a4be5e1ef14f1f4aeaa871a2c2b8b837 Mon Sep 17 00:00:00 2001
From: ROM Benchmark <rom-benchmark@local>
Date: Mon, 11 May 2026 18:24:46 -0400
Subject: [PATCH] Reduce fused MLP tile on SM120

---
 triton_kernels.py | 11 +++++++----
 1 file changed, 7 insertions(+), 4 deletions(-)

diff --git a/triton_kernels.py b/triton_kernels.py
index eb1a610..966248a 100644
--- a/triton_kernels.py
+++ b/triton_kernels.py
@@ -1,3 +1,5 @@
+import os
+
 import torch
 import triton
 import triton.language as tl
@@ -481,10 +483,11 @@ def linear_relu_square(a, b, aux=None):
 
     NUM_SMS = torch.cuda.get_device_properties("cuda").multi_processor_count
 
-    BLOCK_SIZE_M = 128
-    BLOCK_SIZE_N = 256
-    BLOCK_SIZE_K = 64
-    num_stages = 4 if FORWARD else 3
+    is_sm120_or_newer = torch.cuda.get_device_capability()[0] >= 12
+    BLOCK_SIZE_M = int(os.environ.get("MLP_BLOCK_SIZE_M", "128"))
+    BLOCK_SIZE_N = int(os.environ.get("MLP_BLOCK_SIZE_N", "128" if is_sm120_or_newer else "256"))
+    BLOCK_SIZE_K = int(os.environ.get("MLP_BLOCK_SIZE_K", "64"))
+    num_stages = int(os.environ.get("MLP_NUM_STAGES", "3" if is_sm120_or_newer else ("4" if FORWARD else "3")))
     num_warps = 8
 
     a_desc = TensorDescriptor.from_tensor(a, [BLOCK_SIZE_M, BLOCK_SIZE_K])
